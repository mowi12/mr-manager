Screen {
    layout: vertical;
}

#content {
    height: 1fr;
}

#scan-status-row {
    height: auto;
    margin: 1 1 1 1;
    align: left middle;
}

#scan-status-row.stacked {
    layout: vertical;
    align: left top;
}

#scan-path {
    width: 1fr;
}

#scan-state {
    height: auto;
    width: 1fr;
    align: right middle;
}

#scan-status-row.stacked #scan-state {
    width: 1fr;
    align: left middle;
}

#scan-state-indicator {
    width: auto;
}

#scan-state-result {
    width: auto;
}

#repo-list {
    height: 1fr;
    margin: 0 1 1 1;
}
